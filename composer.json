{
    "name": "plainsimple/cloudflare-sdk-php",
    "description": "PHP SDK for working with Cloudflare API",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "authors": [
        {
            "name": "Viacheslav Zhabonos",
            "email": "vyacheslav0310@gmail.com"
        }
    ],
    "require": {
        "ext-json": "*",
        "php": ">=8.3",
        "psr/http-message": "^2.0",
        "guzzlehttp/guzzle": "^7.9",
        "fig/http-message-util": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpdocumentor/phpdocumentor": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PlainSimple\\Cloudflare\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "phpunit --coverage-text",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint-fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "docs": "phpdoc",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "optimize-autoloader": true,
        "sort-packages": true,
        "cache-dir": "/tmp/composer-cache"
    }
}
